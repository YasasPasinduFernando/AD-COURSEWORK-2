@using AD_COURSEWORK_2.Infrastructure
@model GradeSubmissionViewModel
@{
    ViewData["Title"] = "Grade submission";
    var currentLetter = GradeBandHelper.ToLetter(Model.Grade, Model.MaxPoints);
    var currentPercentage = GradeBandHelper.ToPercentage(Model.Grade, Model.MaxPoints);
}

<h1 class="h3 mb-1">Grade submission</h1>
<p class="text-muted mb-3">@Model.StudentName &middot; Submitted: @(Model.SubmittedAtUtc?.ToLocalTime().ToString("g") ?? "—")</p>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h6">Submission</h2>
                <p class="mb-2"><strong>Text</strong></p>
                <div class="border rounded p-3 bg-light mb-3 small">@(string.IsNullOrWhiteSpace(Model.TextContent) ? "—" : Model.TextContent)</div>
                @if (!string.IsNullOrEmpty(Model.FileName))
                {
                    <a class="btn btn-sm btn-outline-primary" asp-action="SubmissionFile" asp-route-id="@Model.SubmissionId">Download file</a>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Grade" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SubmissionId" />
                    <input type="hidden" asp-for="AssignmentId" />
                    <input type="hidden" asp-for="MaxPoints" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <p class="small text-muted">Maximum points: @Model.MaxPoints.ToString("0.##")</p>
                    <div class="mb-3">
                        <label asp-for="Grade" class="form-label"></label>
                        <input asp-for="Grade" class="form-control" />
                        <span asp-validation-for="Grade" class="text-danger"></span>
                        <div class="form-text">Band preview: <strong id="gradeBandPreview">@currentLetter</strong> (<span id="gradePercentPreview">@currentPercentage.ToString("0.##")</span>%)</div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Feedback" class="form-label"></label>
                        <textarea asp-for="Feedback" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Feedback" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Save grade</button>
                    <a class="btn btn-outline-secondary w-100 mt-2" asp-action="ForAssignment" asp-route-id="@Model.AssignmentId">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const gradeInput = document.getElementById('Grade');
            const maxPoints = Number('@Model.MaxPoints'.replace(',', '.')) || 0;
            const bandEl = document.getElementById('gradeBandPreview');
            const pctEl = document.getElementById('gradePercentPreview');

            function letterFromPercent(p) {
                if (p >= 85) return 'A+';
                if (p >= 75) return 'A';
                if (p >= 65) return 'B';
                if (p >= 55) return 'C';
                if (p >= 45) return 'D';
                return 'F';
            }

            function refreshPreview() {
                if (!gradeInput || !bandEl || !pctEl || maxPoints <= 0) return;
                const grade = Number((gradeInput.value || '0').replace(',', '.')) || 0;
                const pct = Math.max(0, (grade / maxPoints) * 100);
                pctEl.textContent = pct.toFixed(2).replace(/\.00$/, '');
                bandEl.textContent = letterFromPercent(pct);
            }

            gradeInput?.addEventListener('input', refreshPreview);
            refreshPreview();
        })();
    </script>
}
