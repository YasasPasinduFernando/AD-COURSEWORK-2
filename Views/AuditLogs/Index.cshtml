@model List<AD_COURSEWORK_2.Models.AuditLog>
@{
    ViewData["Title"] = "Audit log";
    var category = ViewBag.Category as string;
    var q = ViewBag.Query as string;
    var page = (int)ViewBag.Page;
    var pageSize = (int)ViewBag.PageSize;
    var total = (int)ViewBag.Total;
    var totalPages = (int)ViewBag.TotalPages;
    var categories = (List<string>)ViewBag.Categories;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0">Audit log</h1>
        <p class="text-muted small mb-0">Security and activity trail. @total event@(total == 1 ? "" : "s").</p>
    </div>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Category</label>
            <select name="category" class="form-select">
                <option value="">All</option>
                @foreach (var c in categories)
                {
                    <option value="@c" selected="@(c == category)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label class="form-label small text-muted mb-1">Search (user, action, detail, IP)</label>
            <input type="search" name="q" value="@q" class="form-control" placeholder="e.g. login, john@university.edu, 192.168" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Page size</label>
            <select name="pageSize" class="form-select">
                @foreach (var n in new[] { 25, 50, 100, 200 })
                {
                    <option value="@n" selected="@(n == pageSize)">@n</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Apply</button>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-sm mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width: 12rem;">When (UTC)</th>
                    <th style="width: 8rem;">Category</th>
                    <th>Action</th>
                    <th>User</th>
                    <th>Detail</th>
                    <th style="width: 9rem;">IP</th>
                    <th style="width: 5rem;">OK</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-muted p-4 text-center">No events.</td></tr>
                }
                @foreach (var a in Model)
                {
                    <tr class="@(a.Success ? "" : "table-danger")">
                        <td><small>@a.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</small></td>
                        <td><span class="badge bg-secondary-subtle text-secondary-emphasis">@a.Category</span></td>
                        <td class="fw-semibold">@a.Action</td>
                        <td><small>@(a.UserName ?? "-")</small></td>
                        <td><small class="text-muted">@a.Detail</small></td>
                        <td><small>@(a.IpAddress ?? "-")</small></td>
                        <td>
                            @if (a.Success)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">OK</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger-emphasis">FAIL</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3" aria-label="Audit pagination">
        <ul class="pagination justify-content-center">
            @for (var p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-category="@category"
                       asp-route-q="@q"
                       asp-route-pageSize="@pageSize"
                       asp-route-page="@p">@p</a>
                </li>
            }
        </ul>
        <p class="text-center text-muted small">Page @(page) of @totalPages</p>
    </nav>
}
