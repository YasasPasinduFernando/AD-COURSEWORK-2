@model List<AD_COURSEWORK_2.Models.Assignment>
@{
    ViewData["Title"] = $"{ViewBag.CourseCode} – Assignments";
    var courseId = (int)ViewBag.CourseId;
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">Assignments for @ViewBag.CourseCode</h1>
    <div>
        <a class="btn btn-primary" asp-action="Create" asp-route-courseId="@courseId">New assignment</a>
        <a class="btn btn-outline-secondary" asp-controller="Courses" asp-action="Details" asp-route-id="@courseId">Course</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Due</th>
                    <th>Points</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="text-muted p-4 text-center">No assignments yet.</td></tr>
            }
            @foreach (var a in Model)
            {
                <tr>
                    <td>@a.Title</td>
                    <td>@a.DueDateUtc.ToLocalTime().ToString("g")</td>
                    <td>@a.MaxPoints</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Submissions" asp-action="ForAssignment" asp-route-id="@a.AssignmentId">Submissions</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@a.AssignmentId">Edit</a>
                        <form asp-action="Delete" asp-route-id="@a.AssignmentId" method="post" class="d-inline" onsubmit="return confirm('Delete this assignment?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
