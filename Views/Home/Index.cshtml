@{
    ViewData["Title"] = "UniManage";
}

<section class="hero-section rounded-4 p-4 p-md-5 mb-5 text-white">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="badge bg-light text-primary mb-3">University Course Management System</span>
            <h1 class="display-5 fw-bold mb-3">Manage courses, enrollments, assignments, and communication in one platform.</h1>
            <p class="lead mb-4">UniManage helps students, lecturers, and administrators collaborate with real-time academic workflows and clear reporting.</p>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg">Get Started</a>
                <a href="#about" class="btn btn-outline-light btn-lg">Learn More</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">Platform Highlights</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">Course lifecycle management</li>
                        <li class="mb-2">Enrollment validation and capacity control</li>
                        <li class="mb-2">Assignment submissions and grading</li>
                        <li>Messaging and reporting dashboards</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="card-title mb-3">Students</h4>
                    <p class="card-text text-muted">Browse courses, enroll with prerequisite checks, submit assignments, and track grades and feedback in one place.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="card-title mb-3">Lecturers</h4>
                    <p class="card-text text-muted">Manage assigned courses, upload materials, review submissions, and deliver grading with structured feedback.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body p-4">
                    <h4 class="card-title mb-3">Administrators</h4>
                    <p class="card-text text-muted">Oversee users, course offerings, enrollments, and analytics to maintain an efficient academic system.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="mb-5">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <h2 class="h3 mb-0">Core Modules</h2>
        <span class="badge bg-primary-subtle text-primary-emphasis">Integrated Workflow</span>
    </div>
    <div class="row g-4">
        <div class="col-md-6" id="courses">
            <div class="p-4 bg-white rounded-4 shadow-sm h-100">
                <h5>Course Management</h5>
                <p class="text-muted mb-0">Create, update, and organize courses with lecturer allocation, credits, prerequisites, and capacity limits.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 bg-white rounded-4 shadow-sm h-100">
                <h5>Enrollment</h5>
                <p class="text-muted mb-0">Enable students to enroll with duplicate prevention, prerequisite validation, and real-time seat availability checks.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 bg-white rounded-4 shadow-sm h-100">
                <h5>Assignments</h5>
                <p class="text-muted mb-0">Manage assignment creation, submission tracking, grading, and feedback with clear status visibility.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 bg-white rounded-4 shadow-sm h-100">
                <h5>Reporting</h5>
                <p class="text-muted mb-0">Monitor course popularity, student performance, lecturer workload, and enrollment trends using actionable dashboards.</p>
            </div>
        </div>
        <div class="col-12" id="contact">
            <div class="p-4 bg-white rounded-4 shadow-sm">
                <h5>Messaging</h5>
                <p class="text-muted mb-0">Support direct communication between students and lecturers with conversation-style threads and read status tracking.</p>
            </div>
        </div>
    </div>
</section>
