@{
    ViewData["Title"] = "UniManage";
}

<section class="hero-section rounded-4 p-4 p-md-5 mb-5 text-white">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="badge bg-white bg-opacity-25 text-white border border-white border-opacity-25 mb-3 px-3 py-2">University Course Management System</span>
            <h1 class="display-5 fw-bold mb-3 lh-sm">The modern LMS for <span class="um-hero-accent">Sri&nbsp;Lankan</span> universities.</h1>
            <p class="lead mb-4 opacity-90">Courses, resources, assignments, messaging, and progress analytics — all in one elegant, student‑friendly platform.</p>
            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg px-4 shadow">Create account</a>
                <a href="#about" class="btn btn-outline-light btn-lg px-4">Explore modules</a>
                <a asp-controller="Account" asp-action="LoginWithGoogle" class="btn btn-outline-light btn-lg px-4 d-inline-flex align-items-center gap-2">
                    <img src="~/assets/icons/google-color.svg" alt="" width="18" height="18" />
                    <span>Continue with Google</span>
                </a>
            </div>
            <div class="d-flex flex-wrap gap-4 mt-4 small um-hero-stats">
                <div><span class="h5 fw-bold mb-0 d-block text-white">3</span><span class="opacity-75">User roles</span></div>
                <div><span class="h5 fw-bold mb-0 d-block text-white">5+</span><span class="opacity-75">Core modules</span></div>
                <div><span class="h5 fw-bold mb-0 d-block text-white">24/7</span><span class="opacity-75">Dashboard access</span></div>
            </div>
        </div>
        <div class="col-lg-5">
            <div id="homeCampusCarousel" class="carousel slide rounded-4 overflow-hidden shadow-lg um-hero-carousel" data-bs-ride="carousel" data-bs-interval="3500">
                <div class="carousel-indicators mb-2">
                    <button type="button" data-bs-target="#homeCampusCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                    <button type="button" data-bs-target="#homeCampusCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                    <button type="button" data-bs-target="#homeCampusCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                </div>
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="~/assets/images/lms-campus-1.jpg" class="d-block w-100" alt="University students collaborating">
                        <div class="carousel-caption text-start">
                            <h2 class="h6 fw-bold">Collaborative learning</h2>
                            <p class="small mb-0">Students and lecturers connected through one platform.</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/assets/images/lms-campus-2.jpg" class="d-block w-100" alt="University classroom environment">
                        <div class="carousel-caption text-start">
                            <h2 class="h6 fw-bold">Organized teaching</h2>
                            <p class="small mb-0">Manage lessons, assignments, and feedback with clarity.</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/assets/images/lms-campus-3.jpg" class="d-block w-100" alt="Higher education students on campus">
                        <div class="carousel-caption text-start">
                            <h2 class="h6 fw-bold">Progress-focused dashboards</h2>
                            <p class="small mb-0">Track deadlines, achievements, and academic growth.</p>
                        </div>
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#homeCampusCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#homeCampusCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
            <div class="card border-0 shadow-lg mt-3">
                <div class="card-body p-4">
                    <h2 class="h6 fw-bold mb-3 text-dark">Why UniManage?</h2>
                    <ul class="list-unstyled mb-0 text-secondary small">
                        <li class="d-flex gap-2 mb-2"><span class="text-primary fw-bold">·</span><span>Controlled course lifecycle and enrollment rules</span></li>
                        <li class="d-flex gap-2 mb-2"><span class="text-primary fw-bold">·</span><span>Assignments with submissions and structured feedback</span></li>
                        <li class="d-flex gap-2 mb-2"><span class="text-primary fw-bold">·</span><span>Role-based access for every user type</span></li>
                        <li class="d-flex gap-2"><span class="text-primary fw-bold">·</span><span>Dashboards and analytics for better decisions</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="mb-5" aria-labelledby="roles-heading">
    <h2 id="roles-heading" class="h4 fw-bold mb-4 text-center text-md-start">Built for every role</h2>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 um-role-card role-student shadow-sm">
                <div class="card-body p-4">
                    <div class="um-role-icon um-role-student" aria-hidden="true">S</div>
                    <h3 class="h5 card-title fw-bold">Students</h3>
                    <p class="card-text text-muted small mb-0">Browse the catalog, enroll with prerequisite checks, submit work, and track grades and feedback.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 um-role-card role-lecturer shadow-sm">
                <div class="card-body p-4">
                    <div class="um-role-icon um-role-lecturer" aria-hidden="true">L</div>
                    <h3 class="h5 card-title fw-bold">Lecturers</h3>
                    <p class="card-text text-muted small mb-0">Manage courses, share materials, review submissions, and grade with clear feedback.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 um-role-card role-admin shadow-sm">
                <div class="card-body p-4">
                    <div class="um-role-icon um-role-admin" aria-hidden="true">A</div>
                    <h3 class="h5 card-title fw-bold">Administrators</h3>
                    <p class="card-text text-muted small mb-0">Oversee offerings, enrollments, and reports to keep the institution running smoothly.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="mb-5" aria-labelledby="modules-heading">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-4">
        <h2 id="modules-heading" class="h4 fw-bold mb-0">Core modules</h2>
        <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis px-3 py-2">End-to-end workflow</span>
    </div>
    <div class="row g-4">
        <div class="col-md-6" id="courses">
            <div class="p-4 um-module-tile h-100">
                <h3 class="h5 mb-2">Course management</h3>
                <p class="text-muted small mb-0">Create and maintain courses with lecturers, credits, prerequisites, and capacity.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 um-module-tile h-100">
                <h3 class="h5 mb-2">Enrollment</h3>
                <p class="text-muted small mb-0">Validate prerequisites, prevent duplicates, and respect seat limits.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 um-module-tile h-100">
                <h3 class="h5 mb-2">Assignments</h3>
                <p class="text-muted small mb-0">Publish tasks, collect submissions, and track status through grading.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 um-module-tile h-100">
                <h3 class="h5 mb-2">Reporting</h3>
                <p class="text-muted small mb-0">Course popularity, student performance, workload, and enrollment trends.</p>
            </div>
        </div>
        <div class="col-12" id="contact">
            <div class="p-4 um-module-tile">
                <h3 class="h5 mb-2">Messaging</h3>
                <p class="text-muted small mb-0">Conversation-style threads between students and lecturers with read status.</p>
            </div>
        </div>
    </div>
</section>
