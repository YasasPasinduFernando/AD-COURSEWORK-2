@model DashboardCalendarModel
@{
    var first = new DateTime(Model.Year, Model.Month, 1);
    var daysInMonth = DateTime.DaysInMonth(Model.Year, Model.Month);
    var startDow = (int)first.DayOfWeek;
    var today = DateOnly.FromDateTime(DateTime.Now);
    var dayLabels = new[] { "Su", "Mo", "Tu", "We", "Th", "Fr", "Sa" };
    var totalEvents = Model.EventsByDay.Values.Sum(l => l.Count);

    string KindClass(DashboardCalendarEventKind k) => k switch
    {
        DashboardCalendarEventKind.Material => "kind-material",
        DashboardCalendarEventKind.Submission => "kind-submission",
        DashboardCalendarEventKind.Grade => "kind-grade",
        DashboardCalendarEventKind.Meeting => "kind-meeting",
        _ => "kind-deadline"
    };
    string KindIcon(DashboardCalendarEventKind k) => k switch
    {
        DashboardCalendarEventKind.Material => "bi-upload",
        DashboardCalendarEventKind.Submission => "bi-file-earmark-arrow-up",
        DashboardCalendarEventKind.Grade => "bi-award",
        DashboardCalendarEventKind.Meeting => "bi-camera-video",
        _ => "bi-calendar2-event"
    };
    string KindLabel(DashboardCalendarEventKind k) => k switch
    {
        DashboardCalendarEventKind.Material => "Material",
        DashboardCalendarEventKind.Submission => "Submission",
        DashboardCalendarEventKind.Grade => "Grade",
        DashboardCalendarEventKind.Meeting => "Meeting",
        _ => "Deadline"
    };
}

<div class="um-panel card border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h3 class="h6 mb-0 fw-bold text-dark"><i class="bi bi-calendar3 me-1"></i>@first.ToString("MMMM yyyy")</h3>
                <p class="small text-muted mb-0">Deadlines, materials &amp; submissions</p>
            </div>
            @if (totalEvents > 0)
            {
                <span class="badge bg-primary-subtle text-primary-emphasis rounded-pill">@totalEvents</span>
            }
        </div>

        <div class="um-cal-legend">
            <span class="um-cal-legend-item kind-deadline"><span class="um-cal-dot"></span>Deadline</span>
            <span class="um-cal-legend-item kind-material"><span class="um-cal-dot"></span>Material</span>
            <span class="um-cal-legend-item kind-submission"><span class="um-cal-dot"></span>Submission</span>
            <span class="um-cal-legend-item kind-meeting"><span class="um-cal-dot"></span>Meeting</span>
        </div>

        <div class="um-cal-weekdays">
            @foreach (var dn in dayLabels)
            {
                <div class="um-cal-cellhead text-center">@dn</div>
            }
        </div>
        <div class="um-cal-grid mb-3">
            @for (var i = 0; i < startDow; i++)
            {
                <div class="um-cal-day um-cal-empty"></div>
            }
            @for (var day = 1; day <= daysInMonth; day++)
            {
                var date = new DateOnly(Model.Year, Model.Month, day);
                var has = Model.EventsByDay.TryGetValue(date, out var evs);
                var isToday = date == today;
                var title = has ? string.Join(" · ", evs!.Select(e => e.Title)) : "";
                var kinds = has ? evs!.Select(e => e.Kind).Distinct().OrderBy(k => (int)k).ToList() : new List<DashboardCalendarEventKind>();
                <div class="um-cal-day @(has ? "um-cal-has-event" : "") @(isToday ? "um-cal-today" : "")" title="@title">
                    <span class="um-cal-num">@day</span>
                    @if (has && evs!.Count > 0)
                    {
                        <span class="um-cal-dots">
                            @foreach (var k in kinds.Take(3))
                            {
                                <span class="um-cal-dot @KindClass(k)"></span>
                            }
                        </span>
                    }
                </div>
            }
        </div>

        @if (Model.EventsByDay.Count > 0)
        {
            <div class="border-top pt-3 mt-3">
                <p class="small fw-semibold text-muted text-uppercase mb-2" style="letter-spacing: .04em;">Upcoming</p>
                <ul class="list-unstyled small mb-0 um-cal-list">
                    @foreach (var kv in Model.EventsByDay.OrderBy(k => k.Key).Take(6))
                    {
                        foreach (var e in kv.Value.Take(3))
                        {
                            <li class="d-flex gap-2 py-2 border-bottom border-light align-items-start">
                                <span class="um-cal-ico @KindClass(e.Kind)"><i class="bi @KindIcon(e.Kind)"></i></span>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="d-flex gap-2 align-items-center flex-wrap">
                                        <span class="fw-semibold text-dark text-break">@e.Title</span>
                                        <span class="um-cal-tag @KindClass(e.Kind)">@KindLabel(e.Kind)</span>
                                    </div>
                                    <div class="text-muted small"><i class="bi bi-bookmark me-1"></i>@e.Detail · <i class="bi bi-clock ms-1 me-1"></i>@kv.Key.ToString("MMM d")</div>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        }
        else
        {
            <div class="um-empty mt-3">
                <i class="bi bi-calendar-check"></i>
                <div class="um-empty-title">Nothing scheduled</div>
                <div class="small">Deadlines, materials and submissions will show up here.</div>
            </div>
        }
    </div>
</div>
