@using AD_COURSEWORK_2.Data
@using AD_COURSEWORK_2.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    string NavClass(string controller, string? action = null)
    {
        var isActive = currentController.Equals(controller, StringComparison.OrdinalIgnoreCase)
            && (action == null || currentAction.Equals(action, StringComparison.OrdinalIgnoreCase));
        return isActive ? "nav-link active" : "nav-link";
    }

    int unreadCount = 0;
    if (SignInManager.IsSignedIn(User) && (User.IsInRole(AppRoles.Student) || User.IsInRole(AppRoles.Lecturer)))
    {
        var uid = UserManager.GetUserId(User);
        if (!string.IsNullOrEmpty(uid))
        {
            try
            {
                unreadCount = await DbContext.Messages.CountAsync(m => m.ReceiverId == uid && !m.IsRead);
            }
            catch
            {
                unreadCount = 0;
            }
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniManage</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AD_COURSEWORK_2.styles.css" asp-append-version="true" />
</head>
<body id="top">
    <a class="um-skip" href="#main-content">Skip to content</a>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-um sticky-top py-2">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index" aria-label="UniManage home">UniManage</a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-2 mt-lg-0">
                        <li class="nav-item"><a class="@NavClass("Home", "Index")" asp-controller="Home" asp-action="Index">Home</a></li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item"><a class="@NavClass("Dashboard")" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                            @if (User.IsInRole(AppRoles.Student))
                            {
                                <li class="nav-item"><a class="@NavClass("Enrollments", "Browse")" asp-controller="Enrollments" asp-action="Browse">Catalog</a></li>
                                <li class="nav-item"><a class="@NavClass("Assignments", "Mine")" asp-controller="Assignments" asp-action="Mine">Assignments</a></li>
                                <li class="nav-item"><a class="@NavClass("Meetings")" asp-controller="Meetings" asp-action="Index"><i class="bi bi-camera-video me-1"></i>Meetings</a></li>
                                <li class="nav-item">
                                    <a class="@NavClass("Messages") position-relative" asp-controller="Messages" asp-action="Inbox">
                                        Messages
                                        @if (unreadCount > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: .65rem;">
                                                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
                                                <span class="visually-hidden">unread messages</span>
                                            </span>
                                        }
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole(AppRoles.Lecturer))
                            {
                                <li class="nav-item"><a class="@NavClass("Courses", "MyCourses")" asp-controller="Courses" asp-action="MyCourses">My Courses</a></li>
                                <li class="nav-item"><a class="@NavClass("Meetings")" asp-controller="Meetings" asp-action="Index"><i class="bi bi-camera-video me-1"></i>Meetings</a></li>
                                <li class="nav-item">
                                    <a class="@NavClass("Messages") position-relative" asp-controller="Messages" asp-action="Inbox">
                                        Messages
                                        @if (unreadCount > 0)
                                        {
                                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: .65rem;">
                                                @(unreadCount > 99 ? "99+" : unreadCount.ToString())
                                                <span class="visually-hidden">unread messages</span>
                                            </span>
                                        }
                                    </a>
                                </li>
                                <li class="nav-item"><a class="@NavClass("Reports")" asp-controller="Reports" asp-action="Index">Reports</a></li>
                            }
                            @if (User.IsInRole(AppRoles.Administrator))
                            {
                                <li class="nav-item"><a class="@NavClass("Courses", "Index")" asp-controller="Courses" asp-action="Index">Courses</a></li>
                                <li class="nav-item"><a class="@NavClass("AdminUsers", "Index")" asp-controller="AdminUsers" asp-action="Index">Users</a></li>
                                <li class="nav-item"><a class="@NavClass("Meetings")" asp-controller="Meetings" asp-action="Index"><i class="bi bi-camera-video me-1"></i>Meetings</a></li>
                                <li class="nav-item"><a class="@NavClass("Reports", "Index")" asp-controller="Reports" asp-action="Index">Reports</a></li>
                                <li class="nav-item"><a class="@NavClass("AuditLogs", "Index")" asp-controller="AuditLogs" asp-action="Index">Audit</a></li>
                            }
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="about">About</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" asp-fragment="contact">Contact</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var roleLabel = User.IsInRole(AppRoles.Administrator) ? "Admin" : User.IsInRole(AppRoles.Lecturer) ? "Lecturer" : "Student";
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-inline-flex align-items-center gap-2 py-1 px-lg-2"
                                   href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false"
                                   title="@User.Identity?.Name">
                                    <span class="um-user-avatar">@((User.Identity?.Name ?? "U")[0].ToString().ToUpperInvariant())</span>
                                    <span class="d-none d-lg-inline">
                                        <span class="d-block um-user-name">@User.Identity?.Name</span>
                                        <small class="um-user-role">@roleLabel</small>
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userMenu">
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="bi bi-person-circle me-2"></i>My profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Change password</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Sign out</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="btn btn-sm um-btn-signin ms-lg-2" asp-controller="Account" asp-action="Login">Sign in</a></li>
                            <li class="nav-item"><a class="btn btn-sm btn-register ms-lg-2" asp-controller="Account" asp-action="Register">Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="um-main py-4" id="main-content" tabindex="-1">
        <div class="container">
            <partial name="_Alerts" />
            @RenderBody()
        </div>
    </main>

    <footer class="um-footer py-4">
        <div class="container um-footer-inner small">
            <span class="text-muted">&copy; @DateTime.UtcNow.Year <strong class="text-dark">UniManage</strong> — University Course Management System</span>
            <a class="um-footer-top" href="#top" aria-label="Back to top" title="Back to top">
                <i class="bi bi-chevron-up" aria-hidden="true"></i>
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
