@if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success alert-dismissible fade show um-alert d-flex align-items-start gap-2" role="status">
        <span class="badge rounded-pill bg-success-subtle text-success-emphasis align-self-center">Done</span>
        <div class="flex-grow-1 pt-1">@ok</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Dismiss"></button>
    </div>
}
@if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger alert-dismissible fade show um-alert d-flex align-items-start gap-2" role="alert">
        <span class="badge rounded-pill bg-danger-subtle text-danger-emphasis align-self-center">Error</span>
        <div class="flex-grow-1 pt-1">@err</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Dismiss"></button>
    </div>
}
