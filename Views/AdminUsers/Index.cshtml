@model AD_COURSEWORK_2.ViewModels.AdminUserListViewModel
@{
    ViewData["Title"] = "User management";
}

<div class="um-page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
    <div>
        <h1 class="mb-0">User management</h1>
        <p class="um-lead">Create and manage student, lecturer, and admin accounts. <span class="text-muted">@Model.Total total</span></p>
    </div>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-person-plus me-1"></i>Add user</a>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-8">
            <label class="form-label small text-muted mb-1">Search</label>
            <input type="search" name="q" value="@Model.Query" class="form-control" placeholder="Search by username, name, or email" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Per page</label>
            <select name="pageSize" class="form-select">
                @foreach (var n in new[] { 20, 50, 100 })
                {
                    <option value="@n" selected="@(n == Model.PageSize)">@n</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-primary">Apply</button>
        </div>
    </div>
</form>

@if (Model.AdminCount <= 1)
{
    <div class="alert alert-warning py-2 small">
        Safety mode: only one administrator exists. Editing admin accounts and locking an admin are blocked.
    </div>
}

<div class="um-panel card border-0">
    <div class="table-responsive">
        <table class="table table-hover table-um mb-0 align-middle">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="6" class="text-muted p-4 text-center">No users found.</td></tr>
                }
                @foreach (var u in Model.Users)
                {
                    <tr>
                        <td><span class="badge um-course-code">@u.UserName</span></td>
                        <td class="fw-semibold">@u.FullName</td>
                        <td>@u.Email</td>
                        <td>@u.Role</td>
                        <td>
                            @if (u.IsLocked)
                            {
                                <span class="badge bg-danger-subtle text-danger-emphasis">Locked</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success-emphasis">Active</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            @if (u.IsAdmin && !Model.CanEditAdmin)
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary" disabled title="Editing blocked for only administrator">Edit</button>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id">Edit</a>
                            }

                            @if (u.IsAdmin && !u.IsLocked && !Model.CanLockAdmin)
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger" disabled title="Need at least two admins to lock one">Lock</button>
                            }
                            else
                            {
                                <form asp-action="ToggleLock" asp-route-id="@u.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(u.IsLocked ? "btn-outline-success" : "btn-outline-danger")">
                                        @(u.IsLocked ? "Unlock" : "Lock")
                                    </button>
                                </form>
                            }

                            @if (u.IsAdmin)
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Administrator accounts cannot be deleted">Delete</button>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteUserModal"
                                        data-user-id="@u.Id"
                                        data-user-name="@u.UserName">
                                    Delete
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3" aria-label="Users pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-pageSize="@Model.PageSize" asp-route-page="@(Model.Page - 1)">Prev</a>
            </li>
            @for (var p = Math.Max(1, Model.Page - 3); p <= Math.Min(Model.TotalPages, Model.Page + 3); p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-pageSize="@Model.PageSize" asp-route-page="@p">@p</a>
                </li>
            }
            <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@Model.Query" asp-route-pageSize="@Model.PageSize" asp-route-page="@(Model.Page + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteUserModalLabel">Confirm delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete user <strong id="deleteUserName">this account</strong>?
                <div class="text-danger small mt-2">This action cannot be undone.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteUserId" name="id" />
                    <button type="submit" class="btn btn-danger">Delete user</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const modal = document.getElementById('deleteUserModal');
            if (!modal) return;

            modal.addEventListener('show.bs.modal', event => {
                const btn = event.relatedTarget;
                if (!btn) return;
                const userId = btn.getAttribute('data-user-id') || '';
                const userName = btn.getAttribute('data-user-name') || 'this account';
                const idInput = document.getElementById('deleteUserId');
                const nameEl = document.getElementById('deleteUserName');
                if (idInput) idInput.value = userId;
                if (nameEl) nameEl.textContent = userName;
            });
        })();
    </script>
}
