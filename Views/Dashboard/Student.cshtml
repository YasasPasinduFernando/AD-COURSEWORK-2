@model StudentDashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Student dashboard";
    var firstName = (User.Identity?.Name ?? "Student").Split(' ', '@')[0];
    var greeting = DateTime.Now.Hour < 12 ? "Good morning" : DateTime.Now.Hour < 18 ? "Good afternoon" : "Good evening";
    var pending = Model.UpcomingDeadlines.Count(d => d.Status == "Pending" || d.Status == "Not started" || d.Status == "NotSubmitted");
    var submitted = Model.UpcomingDeadlines.Count(d => d.Status == "Submitted" || d.Status == "Graded");
    var totalTracked = Math.Max(Model.UpcomingDeadlines.Count, 1);
    var progress = Math.Min(100, (int)Math.Round(submitted * 100.0 / totalTracked));
    var circumference = 2 * Math.PI * 54;
    var dashOffset = circumference - (circumference * progress / 100.0);
    var avgGrade = Model.RecentGrades.Where(g => g.Grade.HasValue && g.MaxPoints > 0)
                                      .Select(g => (double)(g.Grade!.Value / g.MaxPoints) * 100)
                                      .DefaultIfEmpty(0).Average();
    var accents = new[] { "", "accent-violet", "accent-emerald", "accent-amber", "accent-rose" };

    var trendLabels = Model.GradeTrend.Select(t => t.Label).ToList();
    var trendValues = Model.GradeTrend.Select(t => Math.Round(t.Value, 1)).ToList();

    string TimeAgo(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return utc.ToLocalTime().ToString("MMM d");
    }
}

<section class="um-welcome">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="um-welcome-eyebrow">Student workspace</div>
            <h1>@greeting, @firstName</h1>
            <p class="um-welcome-sub">Stay on top of your @Model.EnrolledCourses.Count @(Model.EnrolledCourses.Count == 1 ? "course" : "courses"), upcoming deadlines, and feedback — all in one place.</p>
            <div class="um-welcome-chips">
                <span class="um-chip"><i class="bi bi-calendar-event"></i>@DateTime.Now.ToString("dddd, MMM d")</span>
                <span class="um-chip"><i class="bi bi-inbox"></i>@Model.UnreadMessages unread</span>
                <span class="um-chip"><i class="bi bi-mortarboard"></i>Avg @avgGrade.ToString("0")%</span>
                @if (Model.CountOverdue > 0)
                {
                    <span class="um-chip" style="background:rgba(244,63,94,.18); color:#ffd5d8;"><i class="bi bi-exclamation-triangle-fill"></i>@Model.CountOverdue overdue</span>
                }
            </div>
            <div class="um-welcome-cta">
                <a class="btn btn-light" asp-controller="Enrollments" asp-action="Browse"><i class="bi bi-journal-plus me-1"></i> Browse catalog</a>
                <a class="btn btn-outline-light" asp-controller="Assignments" asp-action="Mine"><i class="bi bi-list-check me-1"></i> My assignments</a>
                <a class="btn btn-outline-light" asp-controller="Messages" asp-action="Inbox"><i class="bi bi-chat-dots me-1"></i> Messages</a>
            </div>
        </div>
        <div class="col-lg-4 d-none d-lg-flex justify-content-end">
            <div class="text-center text-white-50 small">
                <div style="font-size:3.5rem; line-height:1;"><i class="bi bi-mortarboard-fill"></i></div>
                <div class="mt-2">UniManage</div>
            </div>
        </div>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="um-stat-card">
            <div class="um-stat-icon"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div class="um-stat-body">
                <span class="um-stat-label">Enrolled</span>
                <span class="um-stat-value">@Model.EnrolledCourses.Count</span>
                <span class="um-stat-hint neutral"><i class="bi bi-bookmark"></i> Active courses</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="um-stat-card stat-amber">
            <div class="um-stat-icon"><i class="bi bi-hourglass-split"></i></div>
            <div class="um-stat-body">
                <span class="um-stat-label">Pending</span>
                <span class="um-stat-value">@pending</span>
                <span class="um-stat-hint @(pending > 0 ? "down" : "up")"><i class="bi bi-@(pending > 0 ? "exclamation-circle" : "check-circle")"></i> Needs action</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="um-stat-card stat-emerald">
            <div class="um-stat-icon"><i class="bi bi-check2-square"></i></div>
            <div class="um-stat-body">
                <span class="um-stat-label">Submitted</span>
                <span class="um-stat-value">@submitted</span>
                <span class="um-stat-hint up"><i class="bi bi-arrow-up-right"></i> @progress% complete</span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="um-stat-card stat-violet">
            <div class="um-stat-icon"><i class="bi bi-chat-dots-fill"></i></div>
            <div class="um-stat-body">
                <span class="um-stat-label">Messages</span>
                <span class="um-stat-value">@Model.UnreadMessages</span>
                <span class="um-stat-hint neutral"><i class="bi bi-envelope"></i> Unread</span>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-8">
        <div class="row g-4 mb-4">
            <div class="col-lg-7">
                <div class="um-panel card border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <div class="um-section-title mb-0"><i class="bi bi-graph-up-arrow me-1"></i>Grade trend</div>
                                <p class="small text-muted mb-0">Last @Model.GradeTrend.Count graded items.</p>
                            </div>
                            @if (Model.GradeTrend.Any())
                            {
                                <span class="um-pill pill-info">Avg @avgGrade.ToString("0")%</span>
                            }
                        </div>
                        @if (Model.GradeTrend.Any())
                        {
                            <div class="um-chart-wrap"><canvas id="studentGradeChart"></canvas></div>
                        }
                        else
                        {
                            <div class="um-empty mt-3">
                                <i class="bi bi-bar-chart"></i>
                                <div class="um-empty-title">No grades yet</div>
                                <div class="small">Once your work is graded, your trend will appear here.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="um-panel card border-0 h-100">
                    <div class="card-body">
                        <div class="um-section-title mb-2"><i class="bi bi-pie-chart me-1"></i>Submission status</div>
                        <div class="um-chart-wrap" style="height: 180px;"><canvas id="studentStatusChart"></canvas></div>
                        <div class="d-flex flex-wrap gap-2 mt-3 small">
                            <span class="um-pill pill-warn">Not started @Model.CountNotStarted</span>
                            <span class="um-pill pill-info">Submitted @Model.CountSubmitted</span>
                            <span class="um-pill pill-success">Graded @Model.CountGraded</span>
                            @if (Model.CountOverdue > 0)
                            {
                                <span class="um-pill pill-rose">Overdue @Model.CountOverdue</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="um-panel card border-0 mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="um-section-title mb-0">My courses</div>
                    <a class="btn btn-sm btn-outline-primary rounded-pill px-3" asp-controller="Enrollments" asp-action="Browse"><i class="bi bi-plus-lg me-1"></i>Browse more</a>
                </div>
                @if (!Model.EnrolledCourses.Any())
                {
                    <div class="um-empty">
                        <i class="bi bi-journal-x"></i>
                        <div class="um-empty-title">No enrollments yet</div>
                        <div class="small">Head to the catalog to join your first course.</div>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @for (var i = 0; i < Model.EnrolledCourses.Count; i++)
                        {
                            var c = Model.EnrolledCourses[i];
                            var accent = accents[i % accents.Length];
                            <div class="col-sm-6 col-lg-4">
                                <a class="um-course-pill @accent" asp-controller="Courses" asp-action="Details" asp-route-id="@c.CourseId">
                                    <span class="course-code">@c.Code</span>
                                    <div class="course-name">@c.Name</div>
                                    <div class="course-meta"><i class="bi bi-person-badge"></i>@c.Lecturer</div>
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @if (Model.UpcomingMeetings.Any())
        {
            <div class="um-panel card border-0 mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="um-section-title mb-0"><i class="bi bi-camera-video text-primary me-1"></i>Upcoming meetings</div>
                        <a class="btn btn-sm btn-outline-primary rounded-pill px-3" asp-controller="Meetings" asp-action="Index"><i class="bi bi-calendar2-event me-1"></i>All sessions</a>
                    </div>
                    <div class="row g-3">
                        @foreach (var mt in Model.UpcomingMeetings)
                        {
                            var local = mt.ScheduledAtUtc.ToLocalTime();
                            var endLocal = local.AddMinutes(mt.DurationMinutes);
                            var canJoinNow = DateTime.Now >= local.AddMinutes(-15) && DateTime.Now <= endLocal;
                            <div class="col-md-6">
                                <div class="um-meet-card @(canJoinNow ? "is-live" : "")">
                                    <div class="um-meet-time text-center">
                                        <div class="um-meet-dow">@local.ToString("ddd")</div>
                                        <div class="um-meet-day">@local.Day</div>
                                        <div class="um-meet-mon">@local.ToString("h:mm tt")</div>
                                    </div>
                                    <div class="flex-grow-1 min-w-0">
                                        <div class="d-flex gap-2 align-items-center mb-1 flex-wrap">
                                            <span class="badge text-bg-light border">@mt.CourseCode</span>
                                            @if (canJoinNow)
                                            {
                                                <span class="badge bg-success-subtle text-success-emphasis"><span class="um-pulse-dot"></span> Live now</span>
                                            }
                                        </div>
                                        <div class="fw-bold text-dark um-meet-title">@mt.Title</div>
                                        <div class="small text-muted um-meet-meta"><i class="bi bi-person-video3 me-1"></i>@mt.LecturerName · @mt.DurationMinutes min</div>
                                        <a class="btn btn-sm @(canJoinNow ? "btn-success" : "btn-outline-primary") mt-2" asp-controller="Meetings" asp-action="Join" asp-route-id="@mt.MeetingId" target="_blank" rel="noopener">
                                            <i class="bi bi-box-arrow-up-right me-1"></i>Join
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="um-panel card border-0 mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="um-section-title mb-0">Upcoming deadlines</div>
                    <a class="btn btn-sm btn-outline-primary rounded-pill px-3" asp-controller="Assignments" asp-action="Mine"><i class="bi bi-list-check me-1"></i>All tasks</a>
                </div>
                @if (!Model.UpcomingDeadlines.Any())
                {
                    <div class="um-empty">
                        <i class="bi bi-calendar-check"></i>
                        <div class="um-empty-title">You're all clear</div>
                        <div class="small">No pending deadlines this week.</div>
                    </div>
                }
                else
                {
                    <ul class="um-timeline">
                        @foreach (var d in Model.UpcomingDeadlines.OrderBy(x => x.DueDateUtc).Take(6))
                        {
                            var due = d.DueDateUtc.ToLocalTime();
                            var state = d.Status == "Graded" ? "is-success" : d.Status == "Submitted" ? "" : due < DateTime.Now ? "is-rose" : due < DateTime.Now.AddDays(2) ? "is-warn" : "";
                            var pillClass = d.Status == "Graded" ? "pill-success" : d.Status == "Submitted" ? "pill-info" : due < DateTime.Now ? "pill-rose" : "pill-warn";
                            <li class="@state">
                                <span class="um-timeline-marker"></span>
                                <div class="d-flex flex-wrap justify-content-between gap-2">
                                    <div>
                                        <p class="um-timeline-title">@d.Title</p>
                                        <div class="um-timeline-meta"><i class="bi bi-bookmark me-1"></i>@d.CourseCode · <i class="bi bi-clock ms-1 me-1"></i>@due.ToString("MMM d, h:mm tt")</div>
                                    </div>
                                    <div class="d-flex gap-2 align-items-center">
                                        <span class="um-pill @pillClass">@d.Status</span>
                                        @if (d.Status != "Graded")
                                        {
                                            <a class="btn btn-sm btn-outline-primary rounded-pill" asp-controller="Submissions" asp-action="Submit" asp-route-id="@d.AssignmentId">Submit</a>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="um-panel card border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="um-section-title mb-0">Recent grades</div>
                    <span class="text-muted small"><i class="bi bi-award me-1"></i>@Model.RecentGrades.Count results</span>
                </div>
                @if (!Model.RecentGrades.Any())
                {
                    <div class="um-empty">
                        <i class="bi bi-clipboard-data"></i>
                        <div class="um-empty-title">No grades yet</div>
                        <div class="small">Your feedback will appear here after marking.</div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-um mb-0 align-middle">
                            <thead><tr><th>Course</th><th>Assignment</th><th>Score</th><th>Feedback</th></tr></thead>
                            <tbody>
                            @foreach (var g in Model.RecentGrades)
                            {
                                var pct = g.Grade.HasValue && g.MaxPoints > 0 ? (int)Math.Round((double)(g.Grade!.Value / g.MaxPoints) * 100) : 0;
                                var pillClass = pct >= 75 ? "pill-success" : pct >= 50 ? "pill-info" : pct > 0 ? "pill-warn" : "pill-muted";
                                <tr>
                                    <td><span class="um-pill pill-info">@g.CourseCode</span></td>
                                    <td class="fw-medium">@g.Assignment</td>
                                    <td><span class="um-pill @pillClass">@g.Grade / @g.MaxPoints · @pct%</span></td>
                                    <td class="small text-muted">@(string.IsNullOrWhiteSpace(g.FeedbackShort) ? "—" : g.FeedbackShort)</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        @{
            var nextDue = Model.UpcomingDeadlines
                .Where(d => d.Status != "Graded" && d.Status != "Submitted" && d.DueDateUtc >= DateTime.UtcNow)
                .OrderBy(d => d.DueDateUtc)
                .FirstOrDefault();
            var daysUntilNext = nextDue == null ? (int?)null : (int)Math.Ceiling((nextDue.DueDateUtc - DateTime.UtcNow).TotalDays);
            var hasGrades = Model.RecentGrades.Any(g => g.Grade.HasValue && g.MaxPoints > 0);
        }
        <div class="um-panel card border-0 mb-4">
            <div class="card-body">
                <div class="um-section-title">Progress snapshot</div>
                <div class="d-flex align-items-center gap-3">
                    <div class="um-ring-wrap">
                        <svg viewBox="0 0 120 120" aria-hidden="true">
                            <defs>
                                <linearGradient id="umRingGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#2563eb" />
                                    <stop offset="55%" stop-color="#6366f1" />
                                    <stop offset="100%" stop-color="#22d3ee" />
                                </linearGradient>
                            </defs>
                            <circle class="um-ring-track" cx="60" cy="60" r="54"></circle>
                            <circle class="um-ring-bar" cx="60" cy="60" r="54"
                                    stroke-dasharray="@circumference.ToString("0.###")"
                                    stroke-dashoffset="@dashOffset.ToString("0.###")"></circle>
                        </svg>
                        <div class="um-ring-center">
                            <div class="um-ring-value">@progress%</div>
                            <div class="um-ring-label">Completed</div>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <div class="small text-muted fw-semibold text-uppercase" style="letter-spacing:.08em;">This term</div>
                        <div class="d-flex flex-column gap-2 mt-2">
                            <div class="um-kpi">
                                <i class="bi bi-mortarboard"></i>
                                <div class="d-flex flex-column">
                                    <span class="kpi-label">Average grade</span>
                                    <span class="kpi-value">@(hasGrades ? avgGrade.ToString("0") + "%" : "—")</span>
                                </div>
                            </div>
                            <div class="um-kpi">
                                <i class="bi bi-alarm"></i>
                                <div class="d-flex flex-column">
                                    <span class="kpi-label">Next deadline</span>
                                    <span class="kpi-value" style="font-size:0.95rem; line-height:1.2;">
                                        @if (daysUntilNext.HasValue)
                                        {
                                            @(daysUntilNext.Value <= 0 ? "Today" : daysUntilNext.Value == 1 ? "Tomorrow" : daysUntilNext.Value + " days")
                                        }
                                        else
                                        {
                                            <span>All clear</span>
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="um-panel card border-0 mb-4">
            <div class="card-body">
                <div class="um-section-title"><i class="bi bi-activity me-1"></i>Recent activity</div>
                @if (!Model.Activity.Any())
                {
                    <div class="um-empty">
                        <i class="bi bi-inboxes"></i>
                        <div class="um-empty-title">No activity yet</div>
                        <div class="small">Your latest grades, submissions and uploads will show up here.</div>
                    </div>
                }
                else
                {
                    <ul class="um-feed list-unstyled mb-0">
                        @foreach (var a in Model.Activity)
                        {
                            <li class="um-feed-item tone-@a.Tone">
                                <span class="um-feed-ico"><i class="bi @a.Icon"></i></span>
                                <div class="flex-grow-1 min-w-0">
                                    <div class="um-feed-title">@a.Title</div>
                                    <div class="um-feed-meta"><i class="bi bi-clock me-1"></i>@TimeAgo(a.WhenUtc)@(string.IsNullOrEmpty(a.Detail) ? "" : " · ") @a.Detail</div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="mb-4">
            <partial name="_DashboardCalendar" model="Model.AssignmentCalendar" />
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const trendLabels = @Html.Raw(JsonSerializer.Serialize(trendLabels));
            const trendValues = @Html.Raw(JsonSerializer.Serialize(trendValues));
            const tEl = document.getElementById('studentGradeChart');
            if (tEl && trendLabels.length > 0) {
                new Chart(tEl, {
                    type: 'line',
                    data: {
                        labels: trendLabels,
                        datasets: [{
                            label: 'Grade %',
                            data: trendValues,
                            borderColor: '#6366f1',
                            backgroundColor: 'rgba(99,102,241,.18)',
                            tension: 0.35,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#6366f1'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, max: 100, ticks: { callback: v => v + '%' } } }
                    }
                });
            }

            const sEl = document.getElementById('studentStatusChart');
            if (sEl) {
                new Chart(sEl, {
                    type: 'doughnut',
                    data: {
                        labels: ['Not started', 'Submitted', 'Graded', 'Overdue'],
                        datasets: [{
                            data: [@Model.CountNotStarted, @Model.CountSubmitted, @Model.CountGraded, @Model.CountOverdue],
                            backgroundColor: ['#f59e0b', '#0ea5e9', '#10b981', '#f43f5e'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } } }
                    }
                });
            }
        })();
    </script>
}
