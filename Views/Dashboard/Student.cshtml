@model StudentDashboardViewModel
@{
    ViewData["Title"] = "Student dashboard";
}

<h1 class="h3 mb-3">Student dashboard</h1>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Courses</h2>
                <p class="display-6 mb-0">@Model.EnrolledCourses.Count</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Upcoming deadlines</h2>
                <p class="display-6 mb-0">@Model.UpcomingDeadlines.Count</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">Unread messages</h2>
                <p class="display-6 mb-0">@Model.UnreadMessages</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">Enrolled courses</h2>
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Enrollments" asp-action="Browse">Catalog</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Code</th><th>Course</th><th>Lecturer</th></tr></thead>
                        <tbody>
                        @if (!Model.EnrolledCourses.Any())
                        {
                            <tr><td colspan="3" class="text-muted">No enrollments.</td></tr>
                        }
                        @foreach (var c in Model.EnrolledCourses)
                        {
                            <tr>
                                <td>@c.Code</td>
                                <td>@c.Name</td>
                                <td>@c.Lecturer</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">Deadlines</h2>
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Assignments" asp-action="Mine">Assignments</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Due</th><th>Course</th><th>Task</th><th>Status</th></tr></thead>
                        <tbody>
                        @if (!Model.UpcomingDeadlines.Any())
                        {
                            <tr><td colspan="4" class="text-muted">No upcoming items.</td></tr>
                        }
                        @foreach (var d in Model.UpcomingDeadlines)
                        {
                            <tr>
                                <td>@d.DueDateUtc.ToLocalTime().ToString("g")</td>
                                <td>@d.CourseCode</td>
                                <td>@d.Title</td>
                                <td><span class="badge bg-secondary">@d.Status</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-4">
    <div class="card-body">
        <h2 class="h5 mb-3">Recent grades</h2>
        <div class="table-responsive">
            <table class="table mb-0">
                <thead><tr><th>Course</th><th>Assignment</th><th>Grade</th><th>Feedback</th></tr></thead>
                <tbody>
                @if (!Model.RecentGrades.Any())
                {
                    <tr><td colspan="4" class="text-muted">No graded work yet.</td></tr>
                }
                @foreach (var g in Model.RecentGrades)
                {
                    <tr>
                        <td>@g.CourseCode</td>
                        <td>@g.Assignment</td>
                        <td>@g.Grade / @g.MaxPoints</td>
                        <td class="small text-muted">@(g.FeedbackShort ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
