@model LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="um-login-wrap">
    <div class="card um-login-card shadow-sm border-0">
        <div class="row g-0">
            <div class="col-lg-5 d-none d-lg-flex um-login-brand p-4 p-xl-5 flex-column">
                <a class="um-auth-logo" asp-controller="Home" asp-action="Index">
                    <span class="um-auth-logo-dot"><i class="bi bi-mortarboard-fill"></i></span>
                    UniManage
                </a>
                <span class="um-auth-badge mb-3"><i class="bi bi-stars"></i> Learning hub</span>
                <h2 class="h3 mb-3">Welcome back to your learning space.</h2>
                <p class="mb-0">Sign in to continue with your courses, assignments, and messages.</p>
                <ul class="um-auth-features">
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-calendar-check"></i></span>
                        <div><strong>Track deadlines</strong><span>See submissions and due dates at a glance.</span></div>
                    </li>
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-journal-text"></i></span>
                        <div><strong>Manage content</strong><span>Share lessons, materials, and feedback with clarity.</span></div>
                    </li>
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-chat-dots"></i></span>
                        <div><strong>Stay connected</strong><span>Built-in messaging keeps everyone in sync.</span></div>
                    </li>
                </ul>
                <div class="um-auth-footer">&copy; @DateTime.UtcNow.Year UniManage · Learning Management System</div>
            </div>
            <div class="col-lg-7">
                <div class="card-body p-4 p-xl-5">
                    <div class="um-auth-head">
                        <h1 class="h3">Sign in</h1>
                        <p>Welcome back — enter your credentials to continue.</p>
                    </div>

                    @if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="um-inline-alert danger"><i class="bi bi-exclamation-triangle-fill"></i><span>@errorMessage</span></div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div asp-validation-summary="ModelOnly" class="um-inline-alert danger"></div>

                        <div class="mb-3">
                            <label asp-for="LoginIdentifier" class="form-label fw-semibold"></label>
                            <div class="um-input-group">
                                <i class="bi bi-person-badge um-input-ico"></i>
                                <input asp-for="LoginIdentifier" class="form-control" autocomplete="username" placeholder="name@university.edu or your.username" />
                            </div>
                            <span asp-validation-for="LoginIdentifier" class="text-danger small"></span>
                        </div>

                        <div class="mb-2">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <div class="um-input-group">
                                <i class="bi bi-lock um-input-ico"></i>
                                <input asp-for="Password" class="form-control has-action" autocomplete="current-password" placeholder="Enter your password" data-pw-input />
                                <button type="button" class="um-input-action" aria-label="Show password" data-pw-toggle><i class="bi bi-eye"></i></button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label small">Keep me signed in</label>
                            </div>
                            <a class="small fw-semibold text-decoration-none" asp-action="ForgotPassword">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg"><i class="bi bi-box-arrow-in-right me-2"></i>Sign in</button>
                    </form>

                    <div class="um-auth-divider">or continue with</div>

                    <a class="btn um-btn-google w-100 d-flex justify-content-center align-items-center gap-2"
                       asp-action="LoginWithGoogle"
                       asp-route-returnUrl="@Model.ReturnUrl">
                        <img src="~/assets/icons/google-color.svg" alt="" width="18" height="18" />
                        <span>Continue with Google</span>
                    </a>

                    <p class="mt-4 mb-0 small text-center text-muted">Don't have an account? <a class="fw-semibold text-decoration-none" asp-action="Register">Create one now</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-pw-toggle]').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = btn.closest('.um-input-group').querySelector('[data-pw-input]');
                if (!input) return;
                const icon = btn.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.className = 'bi bi-eye-slash';
                    btn.setAttribute('aria-label', 'Hide password');
                } else {
                    input.type = 'password';
                    icon.className = 'bi bi-eye';
                    btn.setAttribute('aria-label', 'Show password');
                }
            });
        });
    </script>
}
