@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="um-login-wrap">
    <div class="card um-login-card shadow-sm border-0">
        <div class="row g-0">
            <div class="col-lg-5 d-none d-lg-flex um-login-brand p-4 p-xl-5 flex-column">
                <a class="um-auth-logo" asp-controller="Home" asp-action="Index">
                    <span class="um-auth-logo-dot"><i class="bi bi-mortarboard-fill"></i></span>
                    UniManage
                </a>
                <span class="um-auth-badge mb-3"><i class="bi bi-key"></i> New password</span>
                <h2 class="h3 mb-3">Choose a strong, memorable password.</h2>
                <p class="mb-0">Your reset link is single‑use and expires for security. Once set, sign in with your new password.</p>
                <ul class="um-auth-features">
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-asterisk"></i></span>
                        <div><strong>8+ characters</strong><span>Use a mix of letters, numbers and symbols.</span></div>
                    </li>
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-shield-check"></i></span>
                        <div><strong>Unique</strong><span>Avoid reusing passwords from other sites.</span></div>
                    </li>
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-bell"></i></span>
                        <div><strong>Login alerts</strong><span>You'll get an email on every successful sign‑in.</span></div>
                    </li>
                </ul>
                <div class="um-auth-footer">&copy; @DateTime.UtcNow.Year UniManage</div>
            </div>
            <div class="col-lg-7">
                <div class="card-body p-4 p-xl-5">
                    <div class="um-auth-head">
                        <h1 class="h3">Set a new password</h1>
                        <p>@(string.IsNullOrWhiteSpace(Model?.Email) ? "Enter and confirm your new password below." : $"Resetting password for {Model.Email}.")</p>
                    </div>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="Email" type="hidden" />
                        <input asp-for="Token" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <div class="um-input-group">
                                <i class="bi bi-lock um-input-ico"></i>
                                <input asp-for="Password" class="form-control has-action" autocomplete="new-password" placeholder="At least 8 characters" data-pw-input id="resetPassword" />
                                <button type="button" class="um-input-action" data-pw-toggle aria-label="Show password"><i class="bi bi-eye"></i></button>
                            </div>
                            <div class="um-pw-meter" aria-hidden="true">
                                <div class="um-pw-track" id="pwTrack"><span></span><span></span><span></span><span></span></div>
                                <div class="um-pw-label"><span id="pwLabel">Strength</span><span class="text-muted">8+ chars · mix letters &amp; numbers</span></div>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <div class="um-input-group">
                                <i class="bi bi-lock-fill um-input-ico"></i>
                                <input asp-for="ConfirmPassword" class="form-control has-action" autocomplete="new-password" placeholder="Re-enter new password" data-pw-input />
                                <button type="button" class="um-input-action" data-pw-toggle aria-label="Show password"><i class="bi bi-eye"></i></button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100"><i class="bi bi-shield-lock me-2"></i>Update password</button>
                    </form>

                    <p class="mt-4 mb-0 small text-center text-muted">Changed your mind? <a class="fw-semibold text-decoration-none" asp-action="Login">Return to sign in</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-pw-toggle]').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = btn.closest('.um-input-group').querySelector('[data-pw-input]');
                if (!input) return;
                const icon = btn.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.className = 'bi bi-eye-slash';
                    btn.setAttribute('aria-label', 'Hide password');
                } else {
                    input.type = 'password';
                    icon.className = 'bi bi-eye';
                    btn.setAttribute('aria-label', 'Show password');
                }
            });
        });

        const pwInput = document.getElementById('resetPassword');
        const pwTrack = document.getElementById('pwTrack');
        const pwLabel = document.getElementById('pwLabel');
        if (pwInput && pwTrack && pwLabel) {
            const labels = ['Too short', 'Weak', 'Fair', 'Good', 'Strong'];
            pwInput.addEventListener('input', () => {
                const v = pwInput.value;
                let score = 0;
                if (v.length >= 8) score++;
                if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
                if (/\d/.test(v)) score++;
                if (/[^A-Za-z0-9]/.test(v)) score++;
                if (v.length < 8) score = Math.min(score, 1);
                pwTrack.className = 'um-pw-track level-' + score;
                pwLabel.textContent = labels[score];
            });
        }
    </script>
}
