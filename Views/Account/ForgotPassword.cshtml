@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
}

<div class="um-login-wrap">
    <div class="card um-login-card shadow-sm border-0">
        <div class="row g-0">
            <div class="col-lg-5 d-none d-lg-flex um-login-brand p-4 p-xl-5 flex-column">
                <a class="um-auth-logo" asp-controller="Home" asp-action="Index">
                    <span class="um-auth-logo-dot"><i class="bi bi-mortarboard-fill"></i></span>
                    UniManage
                </a>
                <span class="um-auth-badge mb-3"><i class="bi bi-shield-lock"></i> Password recovery</span>
                <h2 class="h3 mb-3">Forgot your password? No worries.</h2>
                <p class="mb-0">Enter your email and we'll send a secure reset link — good for the next 24 hours.</p>
                <ul class="um-auth-features">
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-envelope-paper"></i></span>
                        <div><strong>Email link</strong><span>A single-use reset link is delivered instantly.</span></div>
                    </li>
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-shield-check"></i></span>
                        <div><strong>Secure</strong><span>Tokens are signed and expire automatically.</span></div>
                    </li>
                    <li>
                        <span class="um-feature-ico"><i class="bi bi-life-preserver"></i></span>
                        <div><strong>Need help?</strong><span>Contact your administrator if you can't receive emails.</span></div>
                    </li>
                </ul>
                <div class="um-auth-footer">Remembered your password? <a class="fw-semibold text-white text-decoration-none" asp-action="Login">Sign in</a></div>
            </div>
            <div class="col-lg-7">
                <div class="card-body p-4 p-xl-5">
                    <div class="um-auth-head">
                        <h1 class="h3">Reset your password</h1>
                        <p>We'll send a secure link to your registered email address.</p>
                    </div>

                    <div class="um-inline-alert">
                        <i class="bi bi-info-circle-fill"></i>
                        <span>For security reasons, we can't confirm whether a given email exists. Check your inbox — and spam folder — after submitting.</span>
                    </div>

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <div class="um-input-group">
                                <i class="bi bi-envelope um-input-ico"></i>
                                <input asp-for="Email" class="form-control" autocomplete="email" placeholder="name@university.edu" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100"><i class="bi bi-send me-2"></i>Send reset link</button>
                    </form>

                    <div class="um-auth-divider">remember it?</div>

                    <a class="btn btn-outline-primary w-100" asp-action="Login"><i class="bi bi-arrow-left me-1"></i> Back to sign in</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
