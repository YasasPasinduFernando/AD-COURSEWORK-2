@{
    ViewData["Title"] = "Access denied";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="um-panel card border-0">
            <div class="card-body p-4 p-md-5 text-center">
                <div class="um-access-icon"><i class="bi bi-shield-exclamation"></i></div>
                <h1 class="h3 fw-bold mb-2">Access denied</h1>
                <p class="text-muted mb-3">You don't have permission to view this resource.</p>

                @if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="um-inline-alert danger text-start"><i class="bi bi-exclamation-triangle-fill"></i><span>@errorMessage</span></div>
                }
                else
                {
                    <div class="um-inline-alert text-start"><i class="bi bi-info-circle-fill"></i><span>If you signed in with Google, your email must already be registered in UniManage to continue.</span></div>
                }

                <div class="d-flex flex-wrap gap-2 justify-content-center mt-4">
                    <a class="btn btn-primary" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Go home</a>
                    <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-1"></i>Sign in</a>
                    <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i>Register</a>
                </div>
            </div>
        </div>
    </div>
</div>
