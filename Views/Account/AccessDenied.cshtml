@{
    ViewData["Title"] = "Access denied";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-5 text-center">
        <h1 class="h3 mb-3">Access denied</h1>
        <p class="text-muted mb-2">You do not have permission to view this resource.</p>
        @if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="text-danger mb-4">@errorMessage</p>
        }
        else
        {
            <p class="text-muted mb-4">If you signed in with Google, your email must already be registered in the LMS.</p>
        }
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Home</a>
        <a class="btn btn-outline-primary" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
    </div>
</div>
