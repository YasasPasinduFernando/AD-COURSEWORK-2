@model AD_COURSEWORK_2.ViewModels.MeetingInputViewModel
@{
    ViewData["Title"] = "Edit meeting";
    var courses = ViewBag.Courses as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<div class="um-page-header">
    <h1 class="mb-0"><i class="bi bi-pencil-square text-primary me-2"></i>Edit meeting</h1>
    <p class="um-lead mb-0">Update the schedule, link, or details. You can re-notify students if anything changed.</p>
</div>

<div class="um-panel card border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" asp-route-id="@Model.MeetingId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MeetingId" />
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CourseId" class="form-label fw-semibold"></label>
                    <select asp-for="CourseId" asp-items="courses" class="form-select"></select>
                    <span asp-validation-for="CourseId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="DurationMinutes" class="form-label fw-semibold"></label>
                    <select asp-for="DurationMinutes" class="form-select">
                        @foreach (var n in new[] { 15, 30, 45, 60, 90, 120, 180 })
                        {
                            <option value="@n">@n minutes</option>
                        }
                    </select>
                </div>

                <div class="col-12">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ScheduledLocal" class="form-label fw-semibold"></label>
                    <input asp-for="ScheduledLocal" type="datetime-local" class="form-control" />
                    <span asp-validation-for="ScheduledLocal" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="MeetingUrl" class="form-label fw-semibold"></label>
                    <input asp-for="MeetingUrl" class="form-control" />
                    <div class="form-text">
                        <input asp-for="AutoGenerate" class="form-check-input me-1" />
                        <label asp-for="AutoGenerate" class="form-check-label small">Auto-generate a new Meet link</label>
                    </div>
                    <span asp-validation-for="MeetingUrl" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold">Agenda / notes</label>
                    <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="NotifyStudents" class="form-check-input" />
                        <label asp-for="NotifyStudents" class="form-check-label">
                            Re-send invite emails to enrolled students
                        </label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check2 me-1"></i>Save changes</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
