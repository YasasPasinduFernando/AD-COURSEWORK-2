@model MessageThreadViewModel
@{
    ViewData["Title"] = $"Chat – {Model.OtherUserName}";
    var avatarPalette = new[] { "", "avatar-violet", "avatar-emerald", "avatar-amber", "avatar-rose" };
    var avatarCls = avatarPalette[Math.Abs(Model.OtherUserName.GetHashCode()) % avatarPalette.Length];
    var ordered = Model.Messages.OrderBy(m => m.SentAtUtc).ToList();

    static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(new[] { ' ', '.', '-' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

}

<div class="um-wa um-wa-thread-only">
    <section class="um-wa-main">
        <header class="um-wa-header">
            <div class="d-flex align-items-center gap-2 min-w-0">
                <a class="um-wa-iconbtn" asp-action="Inbox" title="Back to chats"><i class="bi bi-arrow-left"></i></a>
                <div class="um-avatar avatar-lg @avatarCls">@Initials(Model.OtherUserName)</div>
                <div class="min-w-0">
                    <div class="d-flex align-items-center gap-2">
                        <h1 class="um-wa-name">@Model.OtherUserName</h1>
                        @if (!string.IsNullOrEmpty(Model.OtherUserRole))
                        {
                            <span class="um-wa-role">@Model.OtherUserRole</span>
                        }
                    </div>
                </div>
            </div>
        </header>

        <div class="um-wa-stream" id="chatStream">
            @if (!ordered.Any())
            {
                <div class="um-wa-empty-full">
                    <i class="bi bi-chat-left-text"></i>
                    <div class="fw-bold">No messages yet</div>
                    <div class="small">Send your first message to start the conversation.</div>
                </div>
            }
            else
            {
                foreach (var m in ordered)
                {
                    var local = m.SentAtUtc.ToLocalTime();
                    const string imageTokenPrefix = "[[img:";
                    var rawContent = m.Content ?? string.Empty;
                    string? imageUrl = null;
                    var textContent = rawContent;
                    var lines = rawContent.Replace("\r\n", "\n").Split('\n');
                    if (lines.Length > 0)
                    {
                        var lastLine = lines[^1].Trim();
                        if (lastLine.StartsWith(imageTokenPrefix, StringComparison.OrdinalIgnoreCase) && lastLine.EndsWith("]]", StringComparison.Ordinal))
                        {
                            var candidate = lastLine[imageTokenPrefix.Length..^2];
                            if (!string.IsNullOrWhiteSpace(candidate) && candidate.StartsWith("/uploads/messages/", StringComparison.OrdinalIgnoreCase))
                            {
                                imageUrl = candidate;
                                textContent = string.Join('\n', lines.Take(lines.Length - 1)).Trim();
                            }
                        }
                    }
                    var rowCls = m.IsMine ? "row-mine" : "row-theirs";
                    <div class="um-wa-row @rowCls">
                        <div class="um-wa-bubble">
                            @if (!string.IsNullOrWhiteSpace(textContent))
                            {
                                <div class="um-wa-text">@textContent</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(imageUrl))
                            {
                                <a href="@imageUrl" target="_blank" rel="noopener noreferrer" class="um-wa-image-wrap">
                                    <img src="@imageUrl" alt="Chat image" class="um-wa-image" />
                                </a>
                            }
                            <div class="um-wa-meta">
                                <span class="um-wa-time">@local.ToString("h:mm tt")</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <form class="um-wa-composer" asp-action="Reply" asp-route-id="@Model.OtherUserId" method="post" id="replyForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="file" id="photoInput" name="photo" accept="image/png,image/jpeg,image/gif,image/webp" class="d-none" />
            <button type="button" class="um-wa-iconbtn" title="Upload photo" id="photoBtn"><i class="bi bi-image"></i></button>
            <textarea name="content" id="replyContent"
                      maxlength="16000" rows="1"
                      placeholder="Type a message"></textarea>
            <span class="um-wa-photo-name" id="photoName" aria-live="polite"></span>
            <span class="um-wa-counter" id="replyCharCount" aria-hidden="true">0</span>
            <button type="submit" class="um-wa-send" id="replyBtn" title="Send (Ctrl+Enter)">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        (function () {
            const stream = document.getElementById('chatStream');
            if (stream) stream.scrollTop = stream.scrollHeight;

            const ta = document.getElementById('replyContent');
            const counter = document.getElementById('replyCharCount');
            const form = document.getElementById('replyForm');
            const btn = document.getElementById('replyBtn');
            const photoBtn = document.getElementById('photoBtn');
            const photoInput = document.getElementById('photoInput');
            const photoName = document.getElementById('photoName');

            function autosize() {
                if (!ta) return;
                ta.style.height = 'auto';
                ta.style.height = Math.min(140, ta.scrollHeight) + 'px';
            }
            function update() {
                if (!ta) return;
                if (counter) counter.textContent = (ta.value.length || 0);
                const hasText = ta.value.trim().length > 0;
                const hasPhoto = !!(photoInput && photoInput.files && photoInput.files.length > 0);
                if (btn) btn.disabled = !hasText && !hasPhoto;
                autosize();
            }
            ta?.addEventListener('input', update);
            photoBtn?.addEventListener('click', () => photoInput?.click());
            photoInput?.addEventListener('change', () => {
                const file = (photoInput.files && photoInput.files.length > 0) ? photoInput.files[0] : null;
                if (photoName) photoName.textContent = file ? file.name : '';
                update();
            });
            update();

            ta?.addEventListener('keydown', e => {
                if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
                    e.preventDefault();
                    if (form && ta.value.trim().length > 0) form.submit();
                }
            });

        })();
    </script>
}
