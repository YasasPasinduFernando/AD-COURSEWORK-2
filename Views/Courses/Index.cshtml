@model IEnumerable<AD_COURSEWORK_2.Models.Course>
@{
    ViewData["Title"] = "Manage courses";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="h3 mb-0">Courses</h1>
    <a class="btn btn-primary" asp-action="Create">Add course</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Credits</th>
                    <th>Cap</th>
                    <th>Lecturer</th>
                    <th>Prerequisite</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-muted p-4 text-center">No courses yet.</td></tr>
            }
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Code</td>
                    <td>@c.Name</td>
                    <td>@c.Credits</td>
                    <td>@c.EnrollmentLimit</td>
                    <td>@c.Lecturer.FullName</td>
                    <td>@(c.Prerequisite == null ? "—" : c.Prerequisite.Code)</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@c.CourseId">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.CourseId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@c.CourseId">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
