@model IEnumerable<AD_COURSEWORK_2.Models.Course>
@{
    ViewData["Title"] = "Manage courses";
    var q = ViewBag.Query as string;
    var page = (int)(ViewBag.Page ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 10);
    var total = (int)(ViewBag.Total ?? 0);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="um-page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
    <div>
        <h1 class="mb-0">Courses</h1>
        <p class="um-lead">Manage course catalog, lecturers, and enrollment limits. <span class="text-muted">@total total</span></p>
    </div>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Add course</a>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-7">
            <label class="form-label small text-muted mb-1">Search</label>
            <div class="um-input-group">
                <span class="um-input-ico"><i class="bi bi-search"></i></span>
                <input type="search" name="q" value="@q" class="form-control" placeholder="Search by code, name or lecturer" />
            </div>
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Per page</label>
            <select name="pageSize" class="form-select">
                @foreach (var n in new[] { 10, 25, 50, 100 })
                {
                    <option value="@n" selected="@(n == pageSize)">@n</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100">Apply</button>
            @if (!string.IsNullOrEmpty(q))
            {
                <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
            }
        </div>
    </div>
</form>

<div class="um-panel card border-0">
    <div class="table-responsive">
        <table class="table table-hover table-um mb-0 align-middle">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Credits</th>
                    <th>Cap</th>
                    <th>Lecturer</th>
                    <th>Prerequisite</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-muted p-4 text-center">@(string.IsNullOrEmpty(q) ? "No courses yet." : "No courses match your search.")</td></tr>
            }
            @foreach (var c in Model)
            {
                <tr>
                    <td><span class="badge bg-primary-subtle text-primary-emphasis">@c.Code</span></td>
                    <td class="fw-semibold">@c.Name</td>
                    <td>@c.Credits</td>
                    <td>@c.EnrollmentLimit</td>
                    <td>@c.Lecturer.FullName</td>
                    <td>@(c.Prerequisite == null ? "—" : c.Prerequisite.Code)</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@c.CourseId">View</a>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.CourseId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@c.CourseId">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3" aria-label="Course pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(page == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-pageSize="@pageSize" asp-route-page="@(page - 1)">Prev</a>
            </li>
            @for (var p = Math.Max(1, page - 3); p <= Math.Min(totalPages, page + 3); p++)
            {
                <li class="page-item @(p == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-pageSize="@pageSize" asp-route-page="@p">@p</a>
                </li>
            }
            <li class="page-item @(page == totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-pageSize="@pageSize" asp-route-page="@(page + 1)">Next</a>
            </li>
        </ul>
        <p class="text-center text-muted small">Page @(page) of @totalPages · @total course@(total == 1 ? "" : "s") total</p>
    </nav>
}
