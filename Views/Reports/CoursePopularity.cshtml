@model List<ReportCoursePopularityRow>
@{
    ViewData["Title"] = "Course popularity";
}

<h1 class="h3 mb-3">Course popularity</h1>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Enrolled</th>
                    <th>Capacity</th>
                    <th>Fill rate</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-muted p-4 text-center">No courses.</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Code</td>
                    <td>@r.Name</td>
                    <td>@r.EnrollmentCount</td>
                    <td>@r.Capacity</td>
                    <td>@((r.FillRate * 100).ToString("0"))%</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>
