@model List<ReportCoursePopularityRow>
@using System.Text.Json
@{
    ViewData["Title"] = "Course popularity";
    var topN = Model.Take(12).ToList();
    var labels = topN.Select(r => r.Code).ToList();
    var enrolled = topN.Select(r => r.EnrollmentCount).ToList();
    var capacity = topN.Select(r => r.Capacity).ToList();
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0">Course popularity</h1>
        <p class="text-muted small mb-0">Top @topN.Count of @Model.Count course@(Model.Count == 1 ? "" : "s"), ranked by enrollments.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-success btn-sm" asp-action="CoursePopularityCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</a>
        <a class="btn btn-danger btn-sm" asp-action="CoursePopularityPdf"><i class="bi bi-filetype-pdf me-1"></i>PDF</a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back</a>
    </div>
</div>

@if (Model.Any())
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <canvas id="popularityChart" height="120"></canvas>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Enrolled</th>
                    <th>Capacity</th>
                    <th>Fill rate</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-muted p-4 text-center">No courses.</td></tr>
                }
                @foreach (var r in Model)
                {
                    var pct = (int)Math.Round(r.FillRate * 100);
                    <tr>
                        <td><span class="badge bg-primary-subtle text-primary-emphasis">@r.Code</span></td>
                        <td>@r.Name</td>
                        <td>@r.EnrollmentCount</td>
                        <td>@r.Capacity</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height: 6px;">
                                    <div class="progress-bar @(pct >= 90 ? "bg-danger" : pct >= 60 ? "bg-warning" : "bg-success")" style="width:@(Math.Min(100, pct))%;"></div>
                                </div>
                                <span class="small">@pct%</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @if (Model.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                const labels = @Html.Raw(JsonSerializer.Serialize(labels));
                const enrolled = @Html.Raw(JsonSerializer.Serialize(enrolled));
                const capacity = @Html.Raw(JsonSerializer.Serialize(capacity));
                const ctx = document.getElementById('popularityChart');
                if (!ctx) return;
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: 'Enrolled', data: enrolled, backgroundColor: '#3b82f6' },
                            { label: 'Capacity', data: capacity, backgroundColor: '#cbd5e1' }
                        ]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'top' }, title: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                    }
                });
            })();
        </script>
    }
}
