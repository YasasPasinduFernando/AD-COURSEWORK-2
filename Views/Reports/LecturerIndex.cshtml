@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0"><i class="bi bi-clipboard2-data text-primary me-2"></i>My reports</h1>
        <p class="text-muted small mb-0">Analytics for <strong>your courses</strong> only. Institution-wide exports remain administrator-only.</p>
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-controller="Dashboard" asp-action="Lecturer">Dashboard</a>
</div>

<div class="row g-3">
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-primary-subtle text-primary-emphasis"><i class="bi bi-bar-chart"></i></span>
                    <h2 class="h6 mb-0">My course popularity</h2>
                </div>
                <p class="text-muted small">Enrollment counts and fill rates for courses you teach.</p>
                <a class="btn btn-primary btn-sm" asp-action="CoursePopularity">Open</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-success-subtle text-success-emphasis"><i class="bi bi-graph-up"></i></span>
                    <h2 class="h6 mb-0">My students&rsquo; performance</h2>
                </div>
                <p class="text-muted small">Average graded scores for students enrolled in your courses, based only on your assignments.</p>
                <a class="btn btn-primary btn-sm" asp-action="StudentPerformance">Open</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-warning-subtle text-warning-emphasis"><i class="bi bi-person-workspace"></i></span>
                    <h2 class="h6 mb-0">Workload analysis</h2>
                </div>
                <p class="text-muted small">Your courses, assignments, and submission counts. Export to CSV or PDF.</p>
                <div class="d-flex flex-wrap gap-1">
                    <a class="btn btn-primary btn-sm" asp-action="LecturerWorkload">Open</a>
                    <a class="btn btn-outline-success btn-sm" asp-action="LecturerWorkloadCsv"><i class="bi bi-filetype-csv"></i> CSV</a>
                    <a class="btn btn-danger btn-sm" asp-action="LecturerWorkloadPdf"><i class="bi bi-filetype-pdf"></i> PDF</a>
                </div>
            </div>
        </div>
    </div>
</div>
