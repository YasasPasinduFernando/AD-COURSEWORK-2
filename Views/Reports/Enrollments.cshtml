@model List<ReportEnrollmentRow>
@{
    ViewData["Title"] = "Enrollment report";
}

<h1 class="h3 mb-3">Enrollment report</h1>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Date (UTC)</th>
                    <th>Student</th>
                    <th>Course</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="3" class="text-muted p-4 text-center">No enrollments.</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.DateUtc.ToString("u")</td>
                    <td>@r.Student</td>
                    <td>@r.CourseCode — @r.CourseName</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>
