@model List<ReportStudentPerformanceRow>
@using System.Text.Json
@{
    ViewData["Title"] = "Student performance";
    var withGrades = Model.Where(r => r.AveragePercent.HasValue).Take(15).ToList();
    var labels = withGrades.Select(r => r.StudentName).ToList();
    var values = withGrades.Select(r => Math.Round(r.AveragePercent!.Value, 1)).ToList();
    var overallAvg = Model.Where(r => r.AveragePercent.HasValue).Select(r => r.AveragePercent!.Value).DefaultIfEmpty(0).Average();
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0">Student performance</h1>
        <p class="text-muted small mb-0">Cohort overall average: <strong>@overallAvg.ToString("0.0")%</strong></p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-success btn-sm" asp-action="StudentPerformanceCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</a>
        <a class="btn btn-danger btn-sm" asp-action="StudentPerformancePdf"><i class="bi bi-filetype-pdf me-1"></i>PDF</a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back</a>
    </div>
</div>

@if (withGrades.Any())
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <canvas id="performanceChart" height="120"></canvas>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Student</th>
                    <th>Email</th>
                    <th>Graded items</th>
                    <th>Avg %</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-muted p-4 text-center">No data.</td></tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.StudentName</td>
                        <td><small>@r.Email</small></td>
                        <td>@r.GradedCount</td>
                        <td>@(r.AveragePercent.HasValue ? r.AveragePercent.Value.ToString("0.0") + "%" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @if (withGrades.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                const labels = @Html.Raw(JsonSerializer.Serialize(labels));
                const values = @Html.Raw(JsonSerializer.Serialize(values));
                const ctx = document.getElementById('performanceChart');
                if (!ctx) return;
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{ label: 'Average %', data: values, backgroundColor: '#10b981' }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, max: 100 } }
                    }
                });
            })();
        </script>
    }
}
