@model List<ReportStudentPerformanceRow>
@{
    ViewData["Title"] = "Student performance";
}

<h1 class="h3 mb-3">Student performance</h1>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Student</th>
                    <th>Email</th>
                    <th>Graded items</th>
                    <th>Avg %</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="text-muted p-4 text-center">No data.</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.StudentName</td>
                    <td>@r.Email</td>
                    <td>@r.GradedCount</td>
                    <td>@(r.AveragePercent.HasValue ? r.AveragePercent.Value.ToString("0.0") : "—")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>
