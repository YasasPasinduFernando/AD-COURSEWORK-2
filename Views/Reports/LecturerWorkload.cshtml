@model List<ReportLecturerWorkloadRow>
@using System.Text.Json
@{
    ViewData["Title"] = "Lecturer workload";
    var admin = User.IsInRole(AD_COURSEWORK_2.Models.AppRoles.Administrator);
    var labels = Model.Select(r => r.LecturerName).ToList();
    var courses = Model.Select(r => r.CourseCount).ToList();
    var assignments = Model.Select(r => r.AssignmentCount).ToList();
    var submissions = Model.Select(r => r.SubmissionCount).ToList();
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0">Lecturer workload</h1>
        <p class="text-muted small mb-0">Courses, assignments, and submissions per lecturer.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-success btn-sm" asp-action="LecturerWorkloadCsv"><i class="bi bi-filetype-csv me-1"></i>CSV</a>
        <a class="btn btn-danger btn-sm" asp-action="LecturerWorkloadPdf"><i class="bi bi-filetype-pdf me-1"></i>PDF</a>
        @if (admin)
        {
        }
        else
        {
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Dashboard" asp-action="Lecturer">Dashboard</a>
        }
    </div>
</div>

@if (Model.Any())
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <canvas id="workloadChart" height="120"></canvas>
        </div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-um mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Lecturer</th>
                    <th>Email</th>
                    <th>Courses</th>
                    <th>Assignments</th>
                    <th>Submissions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-muted p-4 text-center">No data.</td></tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.LecturerName</td>
                        <td><small>@r.Email</small></td>
                        <td>@r.CourseCount</td>
                        <td>@r.AssignmentCount</td>
                        <td>@r.SubmissionCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    @if (Model.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                const labels = @Html.Raw(JsonSerializer.Serialize(labels));
                const courses = @Html.Raw(JsonSerializer.Serialize(courses));
                const assignments = @Html.Raw(JsonSerializer.Serialize(assignments));
                const submissions = @Html.Raw(JsonSerializer.Serialize(submissions));
                const ctx = document.getElementById('workloadChart');
                if (!ctx) return;
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: 'Courses', data: courses, backgroundColor: '#6366f1' },
                            { label: 'Assignments', data: assignments, backgroundColor: '#f59e0b' },
                            { label: 'Submissions', data: submissions, backgroundColor: '#10b981' }
                        ]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'top' } },
                        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                    }
                });
            })();
        </script>
    }
}
