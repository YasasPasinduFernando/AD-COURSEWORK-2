@model List<ReportLecturerWorkloadRow>
@{
    ViewData["Title"] = "Lecturer workload";
    var admin = User.IsInRole(AD_COURSEWORK_2.Models.AppRoles.Administrator);
}

<h1 class="h3 mb-3">Lecturer workload</h1>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Lecturer</th>
                    <th>Email</th>
                    <th>Courses</th>
                    <th>Assignments</th>
                    <th>Submissions</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-muted p-4 text-center">No data.</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.LecturerName</td>
                    <td>@r.Email</td>
                    <td>@r.CourseCount</td>
                    <td>@r.AssignmentCount</td>
                    <td>@r.SubmissionCount</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    @if (admin)
    {
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    }
    else
    {
        <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Lecturer">Dashboard</a>
    }
</div>
