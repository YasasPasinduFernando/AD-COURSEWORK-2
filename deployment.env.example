# Copy this file to .env on the deployment server and fill real values there.
# .env is ignored by git and must never be committed.

MYSQL_DATABASE=unimanage
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_ROOT_PASSWORD=rootpassword

# Required when running behind Docker/reverse proxy without a fixed proxy IP.
FORWARDED_HEADERS_TRUST_ALL=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_SENDER_NAME=UniManage LMS
SMTP_SENDER_EMAIL=
SMTP_USERNAME=
SMTP_PASSWORD=
